{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PatchTicket",
  "type": "object",
  "required": [
    "patch_ticket_id",
    "entity_type",
    "entity_id",
    "severity",
    "status"
  ],
  "properties": {
    "patch_ticket_id": { "type": "string" },
    "entity_type": { "type": "string" },
    "entity_id": { "type": "string" },
    "trigger_source": { "type": "string" },
    "issue_type": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "primary_rca_codes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggested_patch_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["open", "triaged", "in_fix", "review_pending", "retest_pending", "closed", "blocked"]
    }
  },
  "additionalProperties": false
}
