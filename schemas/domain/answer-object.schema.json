{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnswerObject",
  "type": "object",
  "required": [
    "object_id",
    "object_type",
    "canonical_question_id",
    "status",
    "review_state",
    "version",
    "updated_at",
    "answer_short",
    "answer_full",
    "decision_criteria"
  ],
  "properties": {
    "object_id": { "type": "string" },
    "object_type": { "const": "AnswerObject" },
    "canonical_question_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "in_review", "review_blocked", "approved", "published", "deprecated", "archived"]
    },
    "review_state": {
      "type": "string",
      "enum": ["unreviewed", "evidence_attached", "reviewed", "conditional_reviewed", "rejected"]
    },
    "version": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string", "format": "date-time" },
    "answer_short": { "type": "string" },
    "answer_full": { "type": "string" },
    "decision_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "explanation"],
        "properties": {
          "label": { "type": "string" },
          "explanation": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "fit_summary": {
      "type": "object",
      "properties": {
        "recommended_for": { "type": "array", "items": { "type": "string" } },
        "caution_for": { "type": "array", "items": { "type": "string" } },
        "not_for": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "linked_proof_object_ids": { "type": "array", "items": { "type": "string" } },
    "linked_boundary_object_ids": { "type": "array", "items": { "type": "string" } },
    "linked_action_object_ids": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
